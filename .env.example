# ═══════════════════════════════════════════════════════════════════════════════
# OIP LITE - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Required fields are marked with (REQUIRED).
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Core
# ─────────────────────────────────────────────────────────────────────────────
# (REQUIRED) Secret used to sign JWT tokens for user authentication
JWT_SECRET=change-me-to-a-long-random-string

PORT=3005
OIP_DAEMON_PORT=3005
REGISTRATION_LIMIT=50

# Maximum number of user registrations allowed
REGISTRATION_LIMIT=50

# (REQUIRED for publishing to Arweave) Path to your Arweave wallet JSON keyfile
# Used to FUND Arweave transactions (pay for storage). Standard Arweave wallets are RSA
# format and cannot be used for OIP v0.9 signing — see SERVER_CREATOR_MNEMONIC below.
WALLET_FILE=config/arweave-keyfile.json
ARWEAVE_KEY_FILE=config/arweave-keyfile.json

# (REQUIRED for register.html and OIP v0.9 record publishing)
# The server's OIP signing identity, derived from a BIP-39 mnemonic.
# This is what the server uses to co-sign records published to Arweave.
# Because standard Arweave wallets are RSA-format (incompatible with OIP's secp256k1
# signing), SERVER_CREATOR_MNEMONIC is the practical way to give the server a signing
# identity. Generate a 12-word mnemonic (e.g. via register.html "Generate Test Mnemonic")
# and set it here. The derived DID becomes the server's creator address.
SERVER_CREATOR_MNEMONIC=

# ─────────────────────────────────────────────────────────────────────────────
# Public URL
# ─────────────────────────────────────────────────────────────────────────────
# Set to your public domain when deploying (used for media URL generation)
# Leave empty for local development (auto-detects from requests)
# Example: https://oip.example.com  or  https://yournode.ngrok-free.app
PUBLIC_API_BASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Multi-Stack Deployment
# ─────────────────────────────────────────────────────────────────────────────
# Unique name to avoid Docker conflicts when running multiple OIP stacks
# Affects container names, network names, and volume names
COMPOSE_PROJECT_NAME=oip-lite

# ─────────────────────────────────────────────────────────────────────────────
# Arweave Indexing
# ─────────────────────────────────────────────────────────────────────────────
# Set to false to disable automatic blockchain indexing (web server only mode)
ARWEAVE_SYNC_ENABLED=true

# Initial delay before starting keepDBUpToDate (seconds)
KEEP_DB_DELAY=15
# Interval between Arweave sync refreshes (seconds)
KEEP_DB_REFRESH=600

# ─────────────────────────────────────────────────────────────────────────────
# AR.IO Gateway (Local Arweave Gateway - optional)
# ─────────────────────────────────────────────────────────────────────────────
# Set to true to use a local AR.IO gateway instead of arweave.net
USE_LOCAL_ARIO_GATEWAY=false
# Address of your local AR.IO gateway (host:port)
LOCAL_ARIO_GATEWAY_ADDRESS=ario-gateway:4000
# Maximum block gap allowed when falling back to arweave.net
MAX_BLOCK_GAP_FOR_FALLBACK=100

# ─────────────────────────────────────────────────────────────────────────────
# Elasticsearch
# ─────────────────────────────────────────────────────────────────────────────
ELASTICSEARCHHOST=http://elasticsearch:9200
ELASTICCLIENTUSERNAME=elastic
ELASTICCLIENTPASSWORD=changeme

# Path where Elasticsearch data is stored on the host filesystem
# Use an absolute path for large deployments (e.g., /data/elasticsearch)
ELASTICSEARCH_DATA_PATH=./elasticsearch_data

# How often to recreate the ES client to prevent memory leaks (ms, default: 30 min)
ES_CLIENT_RECREATION_INTERVAL=1800000

# How often to recreate the Arweave GraphQL client (ms, default: 30 min)
GRAPHQL_CLIENT_RECREATION_INTERVAL=1800000

# Block height cache TTL (ms, default: 1 hour)
BLOCK_HEIGHT_CACHE_TTL=3600000

# ─────────────────────────────────────────────────────────────────────────────
# GUN (Private/Peer-to-Peer Record Storage)
# ─────────────────────────────────────────────────────────────────────────────
GUN_PEERS=http://gun-relay:8765
GUN_ENABLE_ENCRYPTION=true
GUN_DEFAULT_PRIVACY=false

# Cross-node sync: set to true to pull records from other OIP nodes via GUN
GUN_SYNC_ENABLED=false

# How often to check for new records from other nodes (ms, default: 5 min)
GUN_SYNC_INTERVAL=300000

GUN_REGISTRY_ROOT=oip:registry
GUN_NODE_ID_OVERRIDE=
GUN_SYNC_PRIVATE_RECORDS=false

# Comma-separated list of trusted GUN node URLs to sync from
# Example: https://node1.example.com/gun-relay,https://node2.example.com/gun-relay
GUN_SYNC_TRUSTED_NODES=

# External GUN peers to connect to (in addition to local gun-relay)
GUN_EXTERNAL_PEERS=

# Timeout for GUN registry writes (ms, default: 30 seconds)
GUN_REGISTRY_TIMEOUT_MS=30000

# ─────────────────────────────────────────────────────────────────────────────
# Record Type Indexing
# ─────────────────────────────────────────────────────────────────────────────
# Controls which record types are indexed from Arweave
# Options: all | whitelist | blacklist
RECORD_TYPE_INDEX_MODE=all

# ─────────────────────────────────────────────────────────────────────────────
# Media
# ─────────────────────────────────────────────────────────────────────────────
# Serve static files from parent directory's public/ folder (for multi-app setups)
CUSTOM_PUBLIC_PATH=false

# Enable serving local media files from a directory
ENABLE_LOCAL_MEDIA=false
# Path to local media directory (relative to public path or absolute)
LOCAL_MEDIA_PATH=

# ─────────────────────────────────────────────────────────────────────────────
# Ngrok (Public Tunnel)
# ─────────────────────────────────────────────────────────────────────────────
# Get your auth token at https://dashboard.ngrok.com
NGROK_AUTH_TOKEN=
# Your custom ngrok domain (leave empty for a random URL)
# Example: mynode.ngrok-free.app  or  api.oip.onl (paid custom domain)
NGROK_DOMAIN=

# ─────────────────────────────────────────────────────────────────────────────
# Service Ports
# ─────────────────────────────────────────────────────────────────────────────
# Adjust these if running multiple OIP stacks on the same machine
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_TRANSPORT_PORT=9300
KIBANA_PORT=5601
IPFS_API_PORT=5001
IPFS_GATEWAY_PORT=8080
GUN_RELAY_PORT=8765
NGROK_DASHBOARD_PORT=4040
DEBUG_PORT=9229

# ─────────────────────────────────────────────────────────────────────────────
# Memory & Performance
# ─────────────────────────────────────────────────────────────────────────────
NODE_OPTIONS=--max-old-space-size=4096
MEMORY_DIAGNOSTICS_ENABLED=false

# HTTP server timeouts (ms)
HTTP_SERVER_TIMEOUT_MS=1800000
HTTP_KEEPALIVE_TIMEOUT_MS=2100000
HTTP_HEADERS_TIMEOUT_MS=2100000

# ─────────────────────────────────────────────────────────────────────────────
# Timezone
# ─────────────────────────────────────────────────────────────────────────────
TZ=America/Los_Angeles
